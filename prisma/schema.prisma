generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  phone         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("MEMBER")
  totalSpent    Float     @default(0)
  sharePercent  Float     @default(0)
  shareAmount   Float     @default(0)
  affiliateCode String?   @unique
  affiliateRate Float     @default(0.05)
  affiliateBalance Float  @default(0)
  referredBy    String?
  freeCoursesLeft Int     @default(0)
  courseDiscount  Float   @default(0)
  isActive        Boolean @default(true)
  parentShareholderId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  courseEnrollments CourseEnrollment[]
  affiliateEarnings AffiliateEarning[]
  parentShareholder User?   @relation("ShareholderTree", fields: [parentShareholderId], references: [id])
  followers         User[]  @relation("ShareholderTree")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Room {
  id          String   @id @default(cuid())
  name        String
  type        String
  capacity    Int
  pricePerNight Float
  memberPrice   Float?
  tipService  Float    @default(50000)
  tipWcBedding Float   @default(0)
  totalUnits   Int     @default(1)
  description String?
  images      String?
  amenities   String?
  isAvailable Boolean  @default(true)
  bookings    Booking[]
}

model BlockedDate {
  id        String   @id @default(cuid())
  checkIn   DateTime
  checkOut  DateTime
  reason    String
  createdAt DateTime @default(now())
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  type        String
  status      String   @default("PENDING")
  checkIn     DateTime?
  checkOut    DateTime?
  guests      Int      @default(1)
  rooms       String?
  roomId      String?
  roomQty     Int      @default(1)

  includeKitchen    Boolean @default(false)
  kitchenTip        Float   @default(0)
  includeBreakfast  Boolean @default(false)
  includeLunch      Boolean @default(false)
  includeDinner     Boolean @default(false)
  includeCampfire   Boolean @default(false)
  campfirePrice     Float   @default(0)

  basePrice     Float    @default(0)
  tipWcBedding  Float    @default(0)
  servicesPrice Float    @default(0)
  serviceItems  String?  // JSON: [{name, price}]
  discount      Float    @default(0)
  totalPrice    Float    @default(0)

  isFullVillage Boolean @default(false)
  companyName   String?
  purpose       String?

  notes       String?
  bookingCode String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  room        Room?    @relation(fields: [roomId], references: [id])
}

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  duration    String
  price       Float
  originalPrice Float?
  maxStudents Int      @default(20)
  schedule    String?
  instructor  String?
  curriculum  String?
  benefits    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  enrollments CourseEnrollment[]
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  status    String   @default("ENROLLED")
  paidPrice Float
  scheduleDate DateTime?
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetRoles String   @default("ALL") // "ALL" | "MEMBER" | "VIP" | "SHAREHOLDER" | "ADMIN"
  isPinned    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String? // emoji hoặc icon name
  price       Float
  priceUnit   String  @default("booking") // "booking" | "person_night" | "person" | "night"
  category    String  @default("food") // "food" | "activity" | "facility"
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
}

model MediaItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("image") // "image" | "video"
  url         String   // image URL or YouTube/video URL
  thumbnail   String?  // for video thumbnails
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AffiliateEarning {
  id          String   @id @default(cuid())
  userId      String
  referredUserId String
  bookingId   String?
  amount      Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
